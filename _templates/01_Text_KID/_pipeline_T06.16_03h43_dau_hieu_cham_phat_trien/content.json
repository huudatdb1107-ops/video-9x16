    "s2": {
      "big_text": "1 TRÊN 6",
      "label": "Trẻ có biểu hiện chậm phát triển",
      "note": "Theo thống kê của WHO, 80% không được phát hiện trước 3 tuổi."
    },
    "s3": {
      "heading": "Ba giai đoạn<br>vàng quan sát",
      "cards": [
        {
          "num": "1",
          "text": "Từ 12-18 tháng: Con chưa bập bẹ, chưa chỉ tay,<br>không quay đầu khi nghe gọi tên. Phản xạ xã hội là dấu chỉ sớm nhất, <em>đừng bỏ qua</em>."
        },
        {
          "num": "2",
          "text": "Từ 2-3 tuổi: Con chưa nói câu hai từ, ít giao tiếp mắt,<br>hành vi lặp lại. <em>Kích thích ngôn ngữ</em> giai đoạn này rất quan trọng."
        },
        {
          "num": "3",
          "text": "Từ 3-5 tuổi: Con khó hòa nhập, chậm tự phục vụ<br>(cầm thìa, mặc áo, vệ sinh). <em>Thấu hiểu</em> từng bước nhỏ."
        }
      ]
    },
    "s4": {
      "quote_mark": "✦",
      "quote_html": "Khi nghi ngờ,<br>đừng chờ.<br>Đừng tự an ủi.<br>Hãy ghi lại <em>những gì quan sát</em> và đi gặp chuyên gia."
    },
    "s5": {
      "heading": "Hành động<br>khi nghi ngờ",
      "items": [
        {
          "text": "Đừng chờ đợi, <em>hãy hành động</em> sớm."
        },
        {
          "text": "Quan sát và ghi lại <em>những biểu hiện</em> của con."
        },
        {
          "text": "Tìm đến chuyên gia để được <em>đánh giá chính xác</em>."
        }
      ]
    },
    "s6": {
      "title": "Phát hiện sớm,<br><em>trao con lợi thế</em>",
      "sub": "Đồng hành cùng con trên hành trình phát triển, với tình yêu thương và sự kiên nhẫn.",
