    "s3": {
      "heading": "Dấu hiệu con<br>bị màn hình kiểm soát",
      "cards": [
        {
          "num": "MỘT",
          "text": "Con <em class=\"hl-teal\">nổi cáu</em>, gào khóc<br>hoặc chống đối khi <em class=\"hl-orange\">bị tắt</em> máy."
