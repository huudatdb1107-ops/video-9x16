        {
          "num": "HAI",
          "text": "Con giảm giao tiếp mắt,<br>ít hứng thú <em class=\"hl-teal\">với đồ</em> chơi."
        },
        {
          "num": "BA",
          "text": "Con khó ngủ, ngủ không sâu,<br>hay cáu <em class=\"hl-teal\">kỉnh buổi</em> sáng."
