{
  "scenes": {
    "s1": {
      "eyebrow": "PHỤ HUYNH CẦN BIẾT",
      "title": "CON <br>KHÓ BẢO,<br><em style=\"color: rgb(255, 122, 42);\">HAY TĂNG ĐỘNG</em>?",
      "byline": ""
    },
    "s2": {
      "big_text": "ADHD",
      "label": "Não bộ khác biệt, <br>cần thấu hiểu",
      "note": "Hành vi KHÔNG phải cố ý chống đối."
    },
    "s3": {
      "heading": "Ba điều cần<br><em>thấu hiểu</em> con",
      "cards": [
        {
          "num": "MỘT",
          "text": "Con chạy nhảy vì hệ <em class=\"hl-teal\">thần kinh</em> cần <em class=\"hl-orange\">kích thích vận động</em> để tự điều hòa."
        },
        {
          "num": "HAI",
          "text": "Con dễ phân tâm <em class=\"hl-teal\">do não</em> ADHD <em class=\"hl-orange\">liên tục quét môi trường</em> xung quanh."
        },
        {
          "num": "BA",
          "text": "Con nổi cáu bộc phát vì vùng <em class=\"hl-teal\">điều tiết cảm xúc</em> chưa <em class=\"hl-orange\">phát triển</em> đủ."
        }
      ],
      "element_times": {
        "c1": 32.5,
        "c2": 40.5,
        "c3": 47.5
      }
    },
    "s4": {
      "quote_mark": "✦",
      "quote_html": "Đứa trẻ nào cũng<br>muốn làm đúng —<br>nếu <em class=\"hl-teal\">con biết</em> cách.<br><em class=\"hl-orange\">Cha mẹ là chìa khóa</em>."
    },
    "s5": {
      "heading": "Thay đổi cách<br><em>tiếp cận</em> con",
      "items": [
        {
          "text": "Thay câu 'con hư' <em class=\"hl-teal\">bằng 'con</em> đang <em class=\"hl-orange\">cần giúp đỡ</em>'."
        },
        {
          "text": "Dán nhãn tích <em class=\"hl-teal\">cực, xây</em> dựng <em class=\"hl-orange\">sự tự tin</em> cho con."
        },
        {
          "text": "<em class=\"hl-teal\">Kiên nhẫn</em> đồng hành, <em class=\"hl-orange\">kết nối</em> với con mỗi ngày."
        }
      ],
      "element_times": {
        "i1": 69.28,
        "i2": 70.59,
        "i3": 71.89
      }
    },
    "s6": {
      "title": "ĐỒNG HÀNH CÙNG CON,<br><em style=\"color: rgb(255, 122, 42);\">YÊU THƯƠNG</em> VÀ <em class=\"hl-custom temp-focus-target\">KIÊN NHẪN</em>",
      "sub": "Theo dõi kênh để không đi một mình — hàng ngàn cha mẹ đang đồng hành cùng con trên hành trình này.",
      "hashtag": "#mevabe"
    }
  },
