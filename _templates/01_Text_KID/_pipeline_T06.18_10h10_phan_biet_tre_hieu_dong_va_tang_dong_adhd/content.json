{
  "scenes": {
    "s1": {
      "eyebrow": "CHUYỆN NUÔI CON",
      "title": "CON CHỈ<br><em>HIẾU ĐỘNG</em> HAY <em>TĂNG ĐỘNG</em>?",
      "byline": ""
    },
    "s2": {
      "big_text": "KHÁC BIỆT",
      "label": "Trẻ h<em class=\"hl-custom temp-focus-target\">i<em class=\"hl-custom\">ếu</em><em class=\"hl-custom\"><em class=\"hl-custom temp-focus-target\"> đ</em></em><em class=\"hl-custom temp-focus-target\"><em class=\"hl-custom temp-focus-target\"><em class=\"hl-custom temp-focus-target\">ộng kh</em>ác</em></em></em><em class=\"hl-custom temp-focus-target\"><em class=\"hl-custom temp-focus-target\"> trẻ</em> </em>tăng động như thế nào?",
      "note": "Phân biệt rõ ràng hai trạng thái để có phương pháp hỗ trợ phù hợp."
    },
    "s3": {
      "heading": "Ba dấu hiệu phân biệt",
      "cards": [
        {
          "num": "01",
          "text": "Trẻ hiếu động ngồi yên khi chơi món đồ <em class=\"hl-teal\">yêu thích</em>.<br>Trẻ tăng động khó <em class=\"hl-orange\">tập trung</em> dù chỉ vài phút."
        },
        {
          "num": "02",
          "text": "Trẻ hiếu động biết <em class=\"hl-teal\">lắng nghe</em> và <em class=\"hl-orange\">tuân thủ</em>.<br>Trẻ tăng động khó kiểm soát cảm xúc và hành vi."
        },
        {
          "num": "03",
          "text": "Trẻ hiếu động tự nhận thức <em class=\"hl-teal\">nguy hiểm</em>.<br>Trẻ tăng động hành động <em class=\"hl-orange\">bộc phát</em>, không nghĩ hậu quả."
        }
      ],
      "element_times": {
        "c1": 20.34,
        "c2": 28.76,
        "c3": 36.46
      }
    },
    "s4": {
      "quote_mark": "✦",
      "quote_html": "Sự thấu hiểu và quan sát tinh tế<br>của cha mẹ chính là<br>chìa khóa vàng giúp con<br><em class=\"hl-teal\">phát triển</em> đúng hướng và <em class=\"hl-orange\">hạnh phúc</em>."
    },
    "s5": {
      "heading": "Ba giải pháp hỗ trợ con",
      "items": [
        {
          "text": "Thiết lập thời biểu sinh hoạt <em class=\"hl-teal\">cố định</em> và <em class=\"hl-orange\">rõ ràng</em> mỗi ngày."
        },
        {
          "text": "Cùng con tham gia các trò chơi vận động có <em class=\"hl-teal\">mục tiêu</em> và <em class=\"hl-orange\">kết nối</em>."
        },
        {
          "text": "<em class=\"hl-teal\">Kiên nhẫn</em> lắng nghe, hạn chế <em class=\"hl-orange\">quát mắng</em>."
        }
      ],
      "element_times": {
        "i2": 27.96
      }
    },
    "s6": {
      "title": "ĐỒNG HÀNH CÙNG CON,<br><em>YÊU THƯƠNG</em> VÀ <em>KIÊN NHẪN</em>",
      "sub": "Nhấn theo dõi kênh để nhận thêm nhiều kiến thức nuôi dạy con bổ ích.",
      "hashtag": "#NuoiDayCon"
    }
  },
